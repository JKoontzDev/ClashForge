# Local development defaults. Copy to `.env` and adjust as needed.
# Plain local Django uses SQLite unless CLASHFORGE_DATABASE=postgres is set.
# Docker Compose overrides CLASHFORGE_DATABASE=postgres and POSTGRES_HOST=postgres.
# Production must explicitly set CLASHFORGE_ENV=production and DJANGO_DEBUG=0.
CLASHFORGE_ENV=development
CLASHFORGE_DATABASE=sqlite
DJANGO_SECRET_KEY=replace-me-for-any-shared-or-production-environment
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
APP_VERSION=0.1.0
BUILD_VERSION=dev

# Production deployment must set CLASHFORGE_ENV=production, DJANGO_DEBUG=0,
# DJANGO_ALLOWED_HOSTS, DJANGO_CSRF_TRUSTED_ORIGINS, PostgreSQL credentials,
# and CLASHFORGE_REDIS_URL. Startup fails closed when production is incomplete.
# Production DJANGO_ALLOWED_HOSTS must contain exact hostnames only, never * or URLs.
# Production DJANGO_CSRF_TRUSTED_ORIGINS must contain HTTPS origins like https://example.com.
POSTGRES_DB=app_db
POSTGRES_USER=clashforge
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CLASHFORGE_REDIS_URL=
CLASHFORGE_CACHE_KEY_PREFIX=clashforge

# Reverse proxy support. Only trust X-Forwarded-For from proxies you control.
# The app must not be directly reachable when CLASHFORGE_TRUST_X_FORWARDED_FOR=1.
# Configure your proxy to overwrite X-Forwarded-For and X-Forwarded-Proto.
DJANGO_USE_X_FORWARDED_HOST=1
CLASHFORGE_TRUST_X_FORWARDED_FOR=0
CLASHFORGE_TRUSTED_PROXY_IPS=
CLASHFORGE_NUM_PROXIES=1

# Admin hardening. Put additional network/VPN restrictions in your proxy.
CLASHFORGE_ADMIN_PATH=admin
CLASHFORGE_THROTTLE_ADMIN_BURST=10/minute
CLASHFORGE_THROTTLE_ADMIN_SUSTAINED=100/hour
CLASHFORGE_THROTTLE_ADMIN_POST_BURST=5/minute
CLASHFORGE_THROTTLE_ADMIN_POST_SUSTAINED=20/hour

# Abuse-protection tuning.
CLASHFORGE_DATA_UPLOAD_MAX_MEMORY_SIZE=65536
CLASHFORGE_DATA_UPLOAD_MAX_NUMBER_FIELDS=64
CLASHFORGE_CSP_ALLOW_UNSAFE_EVAL=0
CLASHFORGE_THROTTLE_DYNAMIC_BURST=180/minute
CLASHFORGE_THROTTLE_DYNAMIC_SUSTAINED=3600/hour
CLASHFORGE_THROTTLE_PAGE_VIEW_BURST=40/minute
CLASHFORGE_THROTTLE_PAGE_VIEW_SUSTAINED=1200/hour
CLASHFORGE_THROTTLE_API_WRITE_BURST=60/minute
CLASHFORGE_THROTTLE_API_WRITE_SUSTAINED=600/hour
CLASHFORGE_THROTTLE_PUBLIC_READ_BURST=5/minute
CLASHFORGE_THROTTLE_PUBLIC_READ_SUSTAINED=300/hour
CLASHFORGE_FIGHTER_WRITE_MAX_BODY_BYTES=4096
CLASHFORGE_BATTLE_RUN_MAX_BODY_BYTES=512
CLASHFORGE_CREATIVE_ASSIST_MAX_BODY_BYTES=6144
CLASHFORGE_THROTTLE_FIGHTER_CREATE_BURST=5/minute
CLASHFORGE_THROTTLE_FIGHTER_CREATE_SUSTAINED=20/hour
CLASHFORGE_THROTTLE_FIGHTER_CREATE_SESSION_SUSTAINED=12/day
CLASHFORGE_THROTTLE_FIGHTER_UPDATE_BURST=5/minute
CLASHFORGE_THROTTLE_FIGHTER_UPDATE_SUSTAINED=30/hour
CLASHFORGE_THROTTLE_FIGHTER_UPDATE_SESSION_SUSTAINED=60/day
CLASHFORGE_THROTTLE_BATTLE_RUN_BURST=5/minute
CLASHFORGE_THROTTLE_BATTLE_RUN_SUSTAINED=30/hour
CLASHFORGE_THROTTLE_BATTLE_RUN_SESSION_SUSTAINED=60/day
CLASHFORGE_BATTLE_SIM_IP_DAILY_QUOTA=5000
CLASHFORGE_BATTLE_SIM_SESSION_DAILY_QUOTA=2000
CLASHFORGE_THROTTLE_CREATIVE_ASSIST_BURST=3/minute
CLASHFORGE_THROTTLE_CREATIVE_ASSIST_SUSTAINED=12/hour
CLASHFORGE_THROTTLE_CREATIVE_ASSIST_SESSION_SUSTAINED=24/day

# Optional local Ollama flavor assistant.
CLASHFORGE_OLLAMA_ENABLED=0
CLASHFORGE_OLLAMA_PUBLIC_API_ENABLED=0
CLASHFORGE_OLLAMA_BASE_URL=http://127.0.0.1:11434
CLASHFORGE_OLLAMA_MODEL=llama3.2:3b
CLASHFORGE_OLLAMA_ALLOWED_MODELS=llama3.2:3b
CLASHFORGE_OLLAMA_TIMEOUT_SECONDS=8
OLLAMA_BIND_ADDR=127.0.0.1
OLLAMA_PORT=11434
CLASHFORGE_SECURITY_LOG_LEVEL=INFO
